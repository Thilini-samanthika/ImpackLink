<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CBE5EF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#0F176B"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivHeaderIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_company" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/ivHeaderIcon"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/ivHeaderIcon"
            android:text="View\nPartnership"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="0.9" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_below="@id/ivHeaderIcon"
            android:layout_marginTop="8dp"
            android:src="@drawable/back"
            app:tint="@android:color/white" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Partnership Card 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ncx b"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnApply1"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/button_green"
                            android:text="apply"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnPending1"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="#D4D43D"
                            android:text="pending"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnDelete1"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="#E53935"
                            android:text="delete"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Partnership Card 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="abc 1"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnApply2"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/button_green"
                            android:text="apply"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnPending2"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="#D4D43D"
                            android:text="pending"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnDelete2"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="#E53935"
                            android:text="delete"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Partnership Card 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="abc 1"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnApply3"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/button_green"
                            android:text="apply"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnPending3"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="#D4D43D"
                            android:text="pending"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnDelete3"
                            android:layout_width="70dp"
                            android:layout_height="32dp"
                            android:layout_marginHorizontal="4dp"
                            android:background="#E53935"
                            android:text="delete"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
