<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D1E8F2">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#0D1B68"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="74dp"
            android:layout_centerVertical="true"
            android:contentDescription="@string/ngo_logo"
            android:src="@drawable/img_19" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/ivLogo"
            android:text="@string/donation_title"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:layout_below="@id/headerBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Donation Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/donation_information"
                        android:textColor="@android:color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Project Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/project_label"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_card_bg"
                            android:backgroundTint="#D9D9D9"
                            android:paddingHorizontal="12dp">

                            <Spinner
                                android:id="@+id/spinnerProjectsUpdate"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent" />

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/right"
                                android:rotation="90"
                                android:contentDescription="@string/back" />
                        </RelativeLayout>
                    </LinearLayout>

                    <!-- Donation Amount -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/donation_amount_label"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etUpdateAmount"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/rounded_card_bg"
                            android:backgroundTint="#D9D9D9"
                            android:hint="@string/donation_amount_hint"
                            android:inputType="number"
                            android:paddingHorizontal="16dp"
                            android:textSize="14sp"
                            android:importantForAutofill="no" />
                    </LinearLayout>

                    <!-- Payment Method -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_method_label"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="35dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/rounded_card_bg"
                                android:backgroundTint="@android:color/white"
                                android:contentDescription="@string/payment_logo_description"
                                android:padding="4dp"
                                android:src="@drawable/visa" />

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="35dp"
                                android:background="@drawable/rounded_card_bg"
                                android:backgroundTint="@android:color/white"
                                android:contentDescription="@string/payment_logo_description"
                                android:padding="4dp"
                                android:src="@drawable/master2" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Pay Now Button -->
                    <Button
                        android:id="@+id/btnPayNowUpdate"
                        android:layout_width="160dp"
                        android:layout_height="50dp"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="#00875A"
                        android:text="@string/pay_now_button"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#D1E8F2"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/nav_home"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_menu_home"
            app:tint="@android:color/black" />

        <ImageButton
            android:id="@+id/navGrid"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Grid"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_apps"
            app:tint="@android:color/black" />

        <ImageButton
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/nav_settings"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_profile_settings"
            app:tint="@android:color/black" />
    </LinearLayout>
</RelativeLayout>
