<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F176B">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="25dp"
        android:src="@drawable/back"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/ngoLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:src="@drawable/app_logo" />

    <LinearLayout
        android:id="@+id/whiteCard"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_below="@id/ngoLogo"
        android:layout_marginTop="30dp"
        android:background="@drawable/curved_white_bg"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Successfully !"
                android:textColor="@color/black"
                android:textSize="35sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:layout_width="263dp"
                android:layout_height="174dp"
                android:layout_marginTop="30dp"
                android:background="@android:color/transparent"
                android:src="@drawable/img_3" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/middleCard"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_alignTop="@id/whiteCard"
        android:layout_marginTop="-35dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/save_pill_bg"
        android:gravity="center_vertical"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:paddingStart="25dp"
        android:paddingEnd="25dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete project"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="45dp"
            android:layout_height="45dp"
            app:cardBackgroundColor="#21B6CD"
            app:cardCornerRadius="22.5dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_ngo" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</RelativeLayout>
