<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BCE3EC"> <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/top_bar"
    android:layout_width="match_parent"
    android:layout_height="65dp"
    android:background="#0D1163"
    app:layout_constraintTop_toTopOf="parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="all notificaton"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/top_bar"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="ngo notification"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:paddingStart="15dp"
                android:background="#D1ECF1"
                android:layout_marginTop="10dp"/>

            <LinearLayout
                android:id="@+id/container_ngo_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="volunteer notification"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:paddingStart="15dp"
                android:background="#D1ECF1"
                android:layout_marginTop="10dp"/>

            <LinearLayout
                android:id="@+id/container_volunteer_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="donor notification"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:paddingStart="15dp"
                android:background="#D1ECF1"
                android:layout_marginTop="10dp"/>
            <LinearLayout
                android:id="@+id/container_donor_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp" />

        </LinearLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#BCE3EC"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivHome"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_home1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ivMenuGrid"
            app:layout_constraintHorizontal_chainStyle="spread" />

        <ImageView
            android:id="@+id/ivMenuGrid"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_apps"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivHome"
            app:layout_constraintEnd_toStartOf="@+id/ivProfileSettings" />

        <ImageView
            android:id="@+id/ivProfileSettings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_profile_user"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivMenuGrid"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>